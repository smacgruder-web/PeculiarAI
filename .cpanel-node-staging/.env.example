# Peculiar AI — cPanel Node.js environment variables
# Copy to .env in the application root on cPanel

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Production site URL
NEXT_PUBLIC_SITE_URL=https://peculiarailabs.com
NEXT_PUBLIC_CONTACT_EMAIL=strategy@peculiarailabs.com

# Google Gemini (server-side only) — restrict key by domain in Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Form delivery via Resend
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Peculiar AI <hello@peculiarailabs.com>
CONTACT_FORM_TO=strategy@peculiarailabs.com

# Optional analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX