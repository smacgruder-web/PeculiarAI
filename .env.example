# Peculiar AI - Environment Variables
# Copy to .env.local (dev) or .env (cPanel production)

NEXT_PUBLIC_SITE_URL=https://peculiarailabs.com
NEXT_PUBLIC_CONTACT_EMAIL=strategy@peculiarailabs.com

# Google Gemini — server-side only; restrict key in Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Form delivery via Resend (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Peculiar AI <hello@peculiarailabs.com>
CONTACT_FORM_TO=strategy@peculiarailabs.com

# Optional: Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX